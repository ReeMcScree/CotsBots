<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="20dp">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bluetooth Connect"
        android:textColor="#2196F3"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Status message (updates when connecting/connected/failed) -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Not connected. Select a paired device below."
        android:textColor="#AAAAAA"
        android:textSize="13sp"
        android:layout_marginBottom="16dp" />

    <!-- Refresh button -->
    <Button
        android:id="@+id/btnRefresh"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Refresh Devices"
        android:backgroundTint="#1565C0"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Paired devices:"
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_marginBottom="6dp" />

    <!-- List of paired BT devices — populated in ConnectFragment.kt -->
    <ListView
        android:id="@+id/listDevices"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#1E1E1E"
        android:divider="#333333"
        android:dividerHeight="0.5dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tip: pair your Romeo board in Android Settings → Bluetooth before opening this app."
        android:textColor="#555555"
        android:textSize="11sp"
        android:paddingTop="12dp" />

</LinearLayout>