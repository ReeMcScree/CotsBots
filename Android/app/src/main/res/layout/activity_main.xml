<?xml version="1.0" encoding="utf-8"?>
<!--
  DrawerLayout is the root — it handles sliding the side drawer in and out.
  Inside it there are two children:
    1. The main content (top bar + fragment container + bottom status bar)
    2. The navigation drawer (slides in from the left)
-->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ========== MAIN CONTENT ========== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#1E1E1E"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <!-- Hamburger button — opens the drawer -->
            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Open menu"
                android:src="@drawable/ic_menu_white_24dp"
                android:tint="#FFFFFF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Robot Controller"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Invisible spacer to keep title centered -->
            <View
                android:layout_width="44dp"
                android:layout_height="44dp" />
        </LinearLayout>

        <!-- Fragment container — ConnectFragment or JoystickFragment goes here -->
        <FrameLayout
            android:id="@+id/fragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#121212" />

        <!-- Bottom status bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#1E1E1E"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <!-- Controller icon — tinted green (connected) or red (disconnected) in code -->
            <ImageView
                android:id="@+id/ivStatus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_gamepad_white_24dp"
                android:tint="#F44336"
                android:contentDescription="Connection status" />

            <TextView
                android:id="@+id/tvDeviceName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Not Connected"
                android:textColor="#AAAAAA"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ========== NAVIGATION DRAWER ========== -->
    <!--
      layout_gravity="start" makes this slide in from the left.
      The actual width is set to half the screen in MainActivity.kt using DisplayMetrics.
      We set a placeholder width here of 280dp.
    -->
    <LinearLayout
        android:id="@+id/navDrawer"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#1E1E1E"
        android:orientation="vertical">

        <!-- Drawer header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#111111"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="≡  Mode Menu"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#333333" />

        <!-- Connect Bluetooth item -->
        <LinearLayout
            android:id="@+id/navConnect"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_bluetooth_white_24dp"
                android:tint="#2196F3"
                android:contentDescription="Bluetooth" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Connect Bluetooth"
                android:textColor="#DDDDDD"
                android:textSize="15sp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#333333" />

        <!-- Joystick Control item -->
        <LinearLayout
            android:id="@+id/navJoystick"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_gamepad_white_24dp"
                android:tint="#4CAF50"
                android:contentDescription="Joystick" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Joystick Control"
                android:textColor="#DDDDDD"
                android:textSize="15sp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#333333" />

        <!-- Terminal item -->
        <LinearLayout
            android:id="@+id/navTerminal"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_menu_white_24dp"
                android:tint="#9C27B0"
                android:contentDescription="Terminal" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Terminal"
                android:textColor="#DDDDDD"
                android:textSize="15sp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#333333" />

        <!-- Follow Ball item -->
        <LinearLayout
            android:id="@+id/navFollowBall"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_sports_soccer_white_24dp"
                android:tint="#FF9800"
                android:contentDescription="Follow Ball" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Follow Ball"
                android:textColor="#DDDDDD"
                android:textSize="15sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>